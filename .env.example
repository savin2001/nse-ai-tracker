# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...            # PUBLIC — safe for browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # PRIVATE — server/workers only

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres
POOLER_URL=postgresql://postgres:password@db.supabase.co:6543/postgres

# ── AI ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # PRIVATE — server/workers only (Claude API)

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=minimum-32-character-random-string-here

# ── Email ────────────────────────────────────────────────
RESEND_API_KEY=re_...               # PRIVATE

# ── API ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000
PORT=4000
